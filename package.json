{
  "name": "astro-noindex",
  "version": "1.0.1",
  "description": "Automatically injects noindex for non-production Astro builds",
  "homepage": "https://velohost.co.uk/plugins/astro-noindex/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velohost/astro-noindex.git"
  },
  "bugs": {
    "url": "https://github.com/velohost/astro-noindex/issues"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "withastro",
    "astro-integration",
    "seo",
    "noindex",
    "robots",
    "staging",
    "static-site"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.0.0"
  }
}
